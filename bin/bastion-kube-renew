#!/usr/bin/env bash
set -euo pipefail

PROGRAM_NAME="bastion-kube-renew"

# --------------------------------------------------
# Resolve bastion library location
# --------------------------------------------------

resolve_lib_dir() {
  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

  [[ -f /usr/local/lib/bastion/log.sh ]] && {
    echo /usr/local/lib/bastion
    return
  }
  [[ -f /usr/lib/bastion/log.sh ]] && {
    echo /usr/lib/bastion
    return
  }
  [[ -f "${script_dir}/../lib/log.sh" ]] && {
    echo "${script_dir}/../lib"
    return
  }
  [[ -f /bastion/lib/log.sh ]] && {
    echo "/bastion/lib"
    return
  }

  echo "bastion library not found" >&2
  exit 1
}

LIB_DIR="$(resolve_lib_dir)"

source "${LIB_DIR}/log.sh"
source "${LIB_DIR}/common.sh"
source "${LIB_DIR}/contract.sh"
source "${LIB_DIR}/audit.sh"

# --------------------------------------------------
# Configuration
# --------------------------------------------------

POLICY="/etc/kubernetes/access-policy.yaml"
BOOTSTRAP="$HOME/.kube/bootstrap"
KUBECONFIG_OUT="$HOME/.kube/config"

# --------------------------------------------------
# Validation (no sudo allowed)
# --------------------------------------------------

if [[ "$EUID" -eq 0 ]]; then
  die "Do not run as root"
fi

[[ -f "$BOOTSTRAP" ]] || die "Missing bootstrap kubeconfig: $BOOTSTRAP"
[[ -f "$POLICY" ]] || die "Policy file not found: $POLICY"

need_cmd kubectl
need_cmd openssl
need_cmd yq
need_cmd base64
need_cmd id
need_cmd mktemp
need_cmd jq

USER_NAME="$(id -un)"

PREFIX="$(yq -r '.csr.groupPrefix' "$POLICY")"
TTL="$(yq -r '.csr.expirationSeconds' "$POLICY")"
SIGNER="$CSR_SIGNER_NAME"

[[ -n "$PREFIX" ]] || die "csr.groupPrefix missing in policy"
[[ -n "$TTL" ]] || die "csr.expirationSeconds missing in policy"
[[ "$TTL" =~ ^[0-9]+$ ]] || die "csr.expirationSeconds must be integer"

if ((TTL < CLIENT_CERT_TTL_MIN_SECONDS)); then
  die "csr.expirationSeconds below min ${CLIENT_CERT_TTL_MIN_SECONDS}"
fi
if ((TTL > CLIENT_CERT_TTL_MAX_SECONDS)); then
  die "csr.expirationSeconds above max ${CLIENT_CERT_TTL_MAX_SECONDS}"
fi

# --------------------------------------------------
# Determine allowed groups
# --------------------------------------------------

mapfile -t GROUPS < <(id -nG | tr ' ' '\n' | grep "^${PREFIX}" || true)

[[ "${#GROUPS[@]}" -gt 0 ]] || die "No ${PREFIX}* groups found for user"

existing_cert_remaining_seconds() {
  [[ -f "$KUBECONFIG_OUT" ]] || {
    printf '%s\n' ""
    return 0
  }

  local cfg_json ctx user cert_data tmp_cert endline not_after exp now

  cfg_json="$(kubectl config view --raw --kubeconfig "$KUBECONFIG_OUT" -o json 2> /dev/null || true)"
  [[ -n "$cfg_json" ]] || {
    printf '%s\n' ""
    return 0
  }

  ctx="$(jq -r '.["current-context"] // ""' <<< "$cfg_json")"
  user="$(jq -r --arg ctx "$ctx" '.contexts[]? | select(.name == $ctx) | .context.user // ""' <<< "$cfg_json" | head -n1)"
  cert_data="$(jq -r --arg user "$user" '.users[]? | select(.name == $user) | .user["client-certificate-data"] // ""' <<< "$cfg_json" | head -n1)"
  [[ -n "$cert_data" ]] || {
    printf '%s\n' ""
    return 0
  }

  tmp_cert="$(mktemp)"
  if ! printf '%s' "$cert_data" | base64 -d > "$tmp_cert" 2> /dev/null; then
    rm -f "$tmp_cert"
    printf '%s\n' ""
    return 0
  fi

  endline="$(openssl x509 -in "$tmp_cert" -noout -enddate 2> /dev/null || true)"
  rm -f "$tmp_cert"
  [[ -n "$endline" ]] || {
    printf '%s\n' ""
    return 0
  }

  not_after="${endline#notAfter=}"
  exp="$(date -d "$not_after" +%s 2> /dev/null || true)"
  now="$(date +%s)"
  [[ -n "$exp" ]] || {
    printf '%s\n' ""
    return 0
  }

  printf '%s\n' "$((exp - now))"
}

check_renew_window() {
  local remaining threshold

  remaining="$(existing_cert_remaining_seconds)"
  [[ -n "$remaining" ]] || return 0

  if ((remaining <= 0)); then
    die "Existing client certificate is expired. Re-enrollment requires new bootstrap token. Ask admin to run: sudo bastion-bootstrap-kubeconfig --user ${USER_NAME}"
  fi

  threshold="$((TTL * CLIENT_CERT_RENEW_WINDOW_PERCENT / 100))"
  ((threshold < CLIENT_CERT_TTL_MIN_SECONDS / 4)) && threshold=$((CLIENT_CERT_TTL_MIN_SECONDS / 4))

  if ((remaining > threshold)); then
    die "Renewal not allowed yet. Remaining cert lifetime is ${remaining}s; renew window opens at <= ${threshold}s"
  fi
}

check_renew_window

log_info "Renewing Kubernetes access for ${USER_NAME}"
log_debug "Groups: ${GROUPS[*]}"
audit_event "cert_renew" "start" "user=${USER_NAME} signer=${SIGNER} ttl=${TTL}"

# --------------------------------------------------
# Generate key + CSR
# --------------------------------------------------

tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT

key="${tmp}/key.pem"
csr="${tmp}/req.csr"

SUBJ="/CN=${USER_NAME}"
for g in "${GROUPS[@]}"; do
  SUBJ="${SUBJ}/O=${g}"
done

log_debug "Generating CSR"

openssl req -new -newkey rsa:2048 -nodes \
  -keyout "$key" \
  -out "$csr" \
  -subj "$SUBJ" > /dev/null 2>&1

csr_name="${USER_NAME}-$(date +%s)"

# --------------------------------------------------
# Submit CSR
# --------------------------------------------------

log_info "Submitting CSR: ${csr_name}"
audit_event "csr_submit" "start" "user=${USER_NAME} csr=${csr_name}"

kubectl --kubeconfig="$BOOTSTRAP" apply -f - > /dev/null << EOF
apiVersion: certificates.k8s.io/v1
kind: CertificateSigningRequest
metadata:
  name: ${csr_name}
  labels:
    bastion-access: "true"
spec:
  signerName: ${SIGNER}
  expirationSeconds: ${TTL}
  request: $(base64 -w0 < "$csr")
  usages:
  - client auth
EOF

audit_event "csr_submit" "ok" "user=${USER_NAME} csr=${csr_name}"
log_info "Waiting for certificate approval..."

cert=""
wait_timeout=300
elapsed=0
backoff=1
while ((elapsed < wait_timeout)); do
  cert=$(kubectl --kubeconfig="$BOOTSTRAP" \
    get csr "$csr_name" \
    -o jsonpath='{.status.certificate}' 2> /dev/null || true)

  [[ -n "$cert" ]] && break

  deny_reason="$(kubectl --kubeconfig="$BOOTSTRAP" get csr "$csr_name" -o jsonpath='{range .status.conditions[*]}{.type}:{.reason}:{.message}{"\n"}{end}' 2> /dev/null | grep '^Denied:' || true)"
  if [[ -n "$deny_reason" ]]; then
    audit_event "csr_wait" "denied" "user=${USER_NAME} csr=${csr_name} reason=${deny_reason}"
    die "CSR denied: ${deny_reason}"
  fi

  sleep "$backoff"
  elapsed=$((elapsed + backoff))
  ((backoff < 15)) && backoff=$((backoff * 2))
done

if [[ -z "$cert" ]]; then
  audit_event "csr_wait" "timeout" "user=${USER_NAME} csr=${csr_name} waited=${elapsed}s"
  die "Timeout waiting for CSR approval/signing after ${elapsed}s"
fi

audit_event "csr_wait" "ok" "user=${USER_NAME} csr=${csr_name}"

echo "$cert" | base64 -d > "${tmp}/cert.pem"

# --------------------------------------------------
# Build kubeconfig (idempotent rebuild)
# --------------------------------------------------

cluster="$(yq -r '.cluster.name' "$POLICY")"
server="$(yq -r '.cluster.server' "$POLICY")"
ca="$(yq -r '.cluster.caFile' "$POLICY")"

[[ -n "$cluster" ]] || die "cluster.name missing in policy"
[[ -n "$server" ]] || die "cluster.server missing in policy"
[[ -n "$ca" ]] || die "cluster.caFile missing in policy"

mkdir -p "$HOME/.kube"

if [[ -f "$KUBECONFIG_OUT" ]]; then
  backup="${KUBECONFIG_OUT}.bak.$(date +%s)"
  cp "$KUBECONFIG_OUT" "$backup"
  log_debug "Backup created: $backup"
fi

log_info "Building kubeconfig"

kubectl config --kubeconfig="$KUBECONFIG_OUT" \
  set-cluster "$cluster" \
  --server="$server" \
  --certificate-authority="$ca" \
  --embed-certs=true > /dev/null

kubectl config --kubeconfig="$KUBECONFIG_OUT" \
  set-credentials "$USER_NAME" \
  --client-certificate="${tmp}/cert.pem" \
  --client-key="$key" \
  --embed-certs=true > /dev/null

kubectl config --kubeconfig="$KUBECONFIG_OUT" \
  set-context "$cluster" \
  --cluster="$cluster" \
  --user="$USER_NAME" > /dev/null

kubectl config --kubeconfig="$KUBECONFIG_OUT" \
  use-context "$cluster" > /dev/null

log_info "✔ Kubernetes access renewed successfully"
audit_event "cert_renew" "ok" "user=${USER_NAME} csr=${csr_name}"

token_meta="/var/lib/bastion/bootstrap-tokens/${USER_NAME}.json"
if [[ -f "$token_meta" ]] && command -v sudo > /dev/null 2>&1; then
  token_id="$(sudo jq -r '.tokenId // empty' "$token_meta" 2> /dev/null || true)"
  if [[ -n "$token_id" ]]; then
    audit_event "bootstrap_token_revoke" "start" "user=${USER_NAME} token_id=${token_id}"
    if sudo bastion-bootstrap-token-revoke --token-id "$token_id" --user "$USER_NAME" --best-effort > /dev/null 2>&1; then
      audit_event "bootstrap_token_revoke" "ok" "user=${USER_NAME} token_id=${token_id}"
    else
      audit_event "bootstrap_token_revoke" "error" "user=${USER_NAME} token_id=${token_id}"
    fi
  fi
fi

kubectl --kubeconfig="$BOOTSTRAP" delete csr "$csr_name" > /dev/null 2>&1 || true
