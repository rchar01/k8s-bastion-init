#!/usr/bin/env bash
set -euo pipefail

PROGRAM_NAME="bastion-kube-renew"

usage() {
  cat << EOF
Usage:
  bastion-kube-renew

Manual renewal wrapper for bastion-renew-cert.
Renewal requires a currently valid certificate in renew window.
EOF
}

main() {
  case "${1:-}" in
    -h | --help)
      usage
      exit 0
      ;;
  esac

  if ! command -v bastion-renew-cert > /dev/null 2>&1; then
    echo "Missing command: bastion-renew-cert" >&2
    exit 1
  fi

  bastion-renew-cert
}

main "$@"
