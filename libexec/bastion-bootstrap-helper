#!/usr/bin/env bash
set -euo pipefail

PROGRAM_NAME="bastion-bootstrap-helper"

resolve_lib_dir() {
  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

  [[ -f /usr/local/lib/bastion/log.sh ]] && {
    echo /usr/local/lib/bastion
    return
  }
  [[ -f /usr/lib/bastion/log.sh ]] && {
    echo /usr/lib/bastion
    return
  }
  [[ -f "${script_dir}/../lib/log.sh" ]] && {
    echo "${script_dir}/../lib"
    return
  }
  [[ -f /bastion/lib/log.sh ]] && {
    echo "/bastion/lib"
    return
  }

  echo "bastion library not found" >&2
  exit 1
}

LIB_DIR="$(resolve_lib_dir)"

source "${LIB_DIR}/log.sh"
source "${LIB_DIR}/common.sh"
source "${LIB_DIR}/contract.sh"
source "${LIB_DIR}/policy.sh"
source "${LIB_DIR}/audit.sh"

ACTION=""
TARGET_USER=""
REASON="login-recovery"
TTL_SECONDS=""
TOKEN_ID=""
JSON_OUTPUT=0
BEST_EFFORT=0

usage() {
  cat << EOF
Usage:
  bastion-bootstrap-helper prepare --user USER [--reason REASON] [--ttl-seconds N] [--json]
  bastion-bootstrap-helper revoke --token-id ID [--best-effort]
EOF
}

parse_args() {
  [[ $# -ge 1 ]] || {
    usage
    exit 1
  }

  ACTION="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user)
        TARGET_USER="$2"
        shift 2
        ;;
      --reason)
        REASON="$2"
        shift 2
        ;;
      --ttl-seconds)
        TTL_SECONDS="$2"
        shift 2
        ;;
      --token-id)
        TOKEN_ID="$2"
        shift 2
        ;;
      --json)
        JSON_OUTPUT=1
        shift
        ;;
      --best-effort)
        BEST_EFFORT=1
        shift
        ;;
      -h | --help)
        usage
        exit 0
        ;;
      *)
        die "Unknown argument: $1"
        ;;
    esac
  done
}

prepare_bootstrap() {
  [[ -n "$TARGET_USER" ]] || die "--user required"

  local requested_ttl
  if [[ -n "$TTL_SECONDS" ]]; then
    requested_ttl="$TTL_SECONDS"
  else
    requested_ttl="$BOOTSTRAP_TOKEN_TTL_DEFAULT_SECONDS"
  fi

  local home_dir primary_group kube_dir bootstrap_path tmp token_json token_id expires_at bootstrap_kubeconfig
  home_dir="$(getent passwd "$TARGET_USER" | cut -d: -f6)"
  primary_group="$(id -gn "$TARGET_USER")"
  [[ -n "$home_dir" ]] || die "User not found: $TARGET_USER"
  [[ -n "$primary_group" ]] || die "Cannot resolve primary group for user: $TARGET_USER"

  kube_dir="${home_dir}/.kube"
  bootstrap_path="${kube_dir}/bootstrap"

  token_json="$(bastion-bootstrap-token-issue --user "$TARGET_USER" --reason "$REASON" --ttl-seconds "$requested_ttl" --json)"
  token_id="$(jq -r '.tokenId // empty' <<< "$token_json")"
  expires_at="$(jq -r '.expiresAt // empty' <<< "$token_json")"
  bootstrap_kubeconfig="$(jq -r '.bootstrapKubeconfig // empty' <<< "$token_json")"

  [[ -n "$token_id" ]] || die "Issuer response missing tokenId"
  [[ -n "$bootstrap_kubeconfig" ]] || die "Issuer response missing bootstrapKubeconfig"

  install -d -m 0700 -o "$TARGET_USER" -g "$primary_group" "$kube_dir"
  tmp="$(mktemp "${kube_dir}/bootstrap.XXXXXX")"
  printf '%s\n' "$bootstrap_kubeconfig" > "$tmp"
  chmod 0600 "$tmp"
  chown "$TARGET_USER:$primary_group" "$tmp"
  mv "$tmp" "$bootstrap_path"

  install -d -m 0700 /var/lib/bastion/bootstrap-tokens
  jq -n \
    --arg user "$TARGET_USER" \
    --arg tokenId "$token_id" \
    --arg expiresAt "$expires_at" \
    --arg reason "$REASON" \
    '{user: $user, tokenId: $tokenId, expiresAt: $expiresAt, reason: $reason}' > "/var/lib/bastion/bootstrap-tokens/${TARGET_USER}.json"
  chmod 0600 "/var/lib/bastion/bootstrap-tokens/${TARGET_USER}.json"

  audit_event "bootstrap_prepare" "ok" "user=${TARGET_USER} token_id=${token_id}"

  if [[ "$JSON_OUTPUT" -eq 1 ]]; then
    jq -n \
      --arg bootstrapPath "$bootstrap_path" \
      --arg tokenId "$token_id" \
      --arg expiresAt "$expires_at" \
      '{bootstrapPath: $bootstrapPath, tokenId: $tokenId, expiresAt: $expiresAt}'
  else
    printf '%s\n' "$bootstrap_path"
  fi
}

revoke_bootstrap() {
  [[ -n "$TOKEN_ID" ]] || die "--token-id required"

  local args=(--token-id "$TOKEN_ID")
  if [[ "${BEST_EFFORT:-0}" -eq 1 ]]; then
    args+=(--best-effort)
  fi

  bastion-bootstrap-token-revoke "${args[@]}"
  audit_event "bootstrap_revoke" "ok" "token_id=${TOKEN_ID}"
}

main() {
  require_root

  need_cmd getent
  need_cmd id
  need_cmd jq
  need_cmd mktemp
  need_cmd bastion-bootstrap-token-issue
  need_cmd bastion-bootstrap-token-revoke

  parse_args "$@"
  policy_read

  case "$ACTION" in
    prepare)
      prepare_bootstrap
      ;;
    revoke)
      revoke_bootstrap
      ;;
    *)
      die "Unknown action: $ACTION"
      ;;
  esac
}

main "$@"
