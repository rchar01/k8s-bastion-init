#!/usr/bin/env bash
set -euo pipefail

PROGRAM_NAME="bastion-bootstrap-kubeconfig"

# --------------------------------------------------
# Resolve bastion library location
# --------------------------------------------------

resolve_lib_dir() {
  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

  [[ -f /usr/local/lib/bastion/log.sh ]] && {
    echo /usr/local/lib/bastion
    return
  }
  [[ -f /usr/lib/bastion/log.sh ]] && {
    echo /usr/lib/bastion
    return
  }
  [[ -f "${script_dir}/../lib/log.sh" ]] && {
    echo "${script_dir}/../lib"
    return
  }
  [[ -f /bastion/lib/log.sh ]] && {
    echo "/bastion/lib"
    return
  }

  echo "bastion library not found" >&2
  exit 1
}

LIB_DIR="$(resolve_lib_dir)"

source "${LIB_DIR}/log.sh"
source "${LIB_DIR}/common.sh"
source "${LIB_DIR}/contract.sh"
source "${LIB_DIR}/audit.sh"

# --------------------------------------------------
# Defaults
# --------------------------------------------------

POLICY=/etc/kubernetes/access-policy.yaml
ADMIN_KUBECONFIG=/etc/kubernetes/admin.kubeconfig
BOOTSTRAP_TOKEN_TTL_SECONDS="${BOOTSTRAP_TOKEN_TTL_DEFAULT_SECONDS}"

TARGET_USER=""
BOOTSTRAP_ALL=0

usage() {
  cat << EOF
Usage:
  bastion-bootstrap-kubeconfig --user USER
  bastion-bootstrap-kubeconfig --all

Options:
  --policy FILE   policy yaml (default: $POLICY)
  --token-ttl-sec N   bootstrap token TTL in seconds (default: ${BOOTSTRAP_TOKEN_TTL_DEFAULT_SECONDS}, max: ${BOOTSTRAP_TOKEN_TTL_MAX_SECONDS})
EOF
}

# --------------------------------------------------
# Args
# --------------------------------------------------

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user)
        TARGET_USER="$2"
        shift 2
        ;;
      --all)
        BOOTSTRAP_ALL=1
        shift
        ;;
      --policy)
        POLICY="$2"
        shift 2
        ;;
      --token-ttl-sec)
        BOOTSTRAP_TOKEN_TTL_SECONDS="$2"
        shift 2
        ;;
      -h | --help)
        usage
        exit 0
        ;;
      *)
        die "Unknown argument: $1"
        ;;
    esac
  done

  if [[ -z "$TARGET_USER" && "$BOOTSTRAP_ALL" -eq 0 ]]; then
    die "Specify --user or --all"
  fi

  [[ "$BOOTSTRAP_TOKEN_TTL_SECONDS" =~ ^[0-9]+$ ]] || die "--token-ttl-sec must be integer"
  if ((BOOTSTRAP_TOKEN_TTL_SECONDS < 60)); then
    die "--token-ttl-sec too small (min 60)"
  fi
  if ((BOOTSTRAP_TOKEN_TTL_SECONDS > BOOTSTRAP_TOKEN_TTL_MAX_SECONDS)); then
    die "--token-ttl-sec exceeds max ${BOOTSTRAP_TOKEN_TTL_MAX_SECONDS}"
  fi
}

# --------------------------------------------------
# Validation
# --------------------------------------------------

validate_policy() {
  [[ -f "$POLICY" ]] || die "Policy not found: $POLICY"
}

policy_has_user() {
  local user="$1"
  yq -e ".users.${user}" "$POLICY" > /dev/null 2>&1
}

# --------------------------------------------------
# Core bootstrap logic
# --------------------------------------------------

bootstrap_user() {
  local user="$1"

  log_info "Bootstrapping kubeconfig for $user"

  policy_has_user "$user" || die "User '$user' not defined in policy"

  local home_dir
  home_dir="$(getent passwd "$user" | cut -d: -f6)"

  local primary_group
  primary_group="$(id -gn "$user")"

  [[ -n "$home_dir" ]] || die "User not found on system: $user"
  [[ -n "$primary_group" ]] || die "Cannot resolve primary group for user: $user"

  local kube_dir="$home_dir/.kube"
  local kubeconfig="$kube_dir/bootstrap"
  local token_json token token_id token_expires token_user

  install -d -o "$user" -g "$primary_group" "$kube_dir"

  local cluster server ca

  cluster=$(yq '.cluster.name' "$POLICY")
  server=$(yq '.cluster.server' "$POLICY")
  ca=$(yq '.cluster.caFile' "$POLICY")

  audit_event "bootstrap_token_issue" "start" "user=$user ttl=${BOOTSTRAP_TOKEN_TTL_SECONDS}"
  token_json="$(bastion-bootstrap-token-issue --user "$user" --ttl-seconds "$BOOTSTRAP_TOKEN_TTL_SECONDS" --json --admin-kubeconfig "$ADMIN_KUBECONFIG")"
  token="$(jq -r '.token // empty' <<< "$token_json")"
  token_id="$(jq -r '.tokenId // empty' <<< "$token_json")"
  token_expires="$(jq -r '.expiresAt // empty' <<< "$token_json")"
  [[ -n "$token" ]] || die "Token issuer returned empty token for user: $user"
  audit_event "bootstrap_token_issue" "ok" "user=$user token_id=${token_id:-unknown} expires_at=${token_expires:-unknown}"

  token_user="bootstrap-${user}"

  install -m 0700 -d /var/lib/bastion/bootstrap-tokens
  jq -n \
    --arg user "$user" \
    --arg tokenId "$token_id" \
    --arg expiresAt "$token_expires" \
    '{user: $user, tokenId: $tokenId, expiresAt: $expiresAt}' > "/var/lib/bastion/bootstrap-tokens/${user}.json"
  chmod 0600 "/var/lib/bastion/bootstrap-tokens/${user}.json"

  kubectl config --kubeconfig="$kubeconfig" \
    set-cluster "$cluster" \
    --server="$server" \
    --certificate-authority="$ca" \
    --embed-certs=true > /dev/null

  kubectl config --kubeconfig="$kubeconfig" \
    set-credentials "$token_user" \
    --token="$token" > /dev/null

  kubectl config --kubeconfig="$kubeconfig" \
    set-context bootstrap \
    --cluster="$cluster" \
    --user="$token_user" > /dev/null

  kubectl config --kubeconfig="$kubeconfig" \
    use-context bootstrap > /dev/null

  chown "$user:$primary_group" "$kubeconfig"

  log_info "Bootstrap kubeconfig installed for $user"
}

bootstrap_all_users() {
  log_info "Bootstrapping all users from policy"

  mapfile -t users < <(yq -r '.users | keys[]' "$POLICY")

  for u in "${users[@]}"; do
    if ! getent passwd "$u" > /dev/null 2>&1; then
      log_warn "User not found on system: $u (skipping)"
      continue
    fi
    bootstrap_user "$u"
  done
}

# --------------------------------------------------
# Main
# --------------------------------------------------

main() {
  require_root

  need_cmd yq
  need_cmd kubectl
  need_cmd getent
  need_cmd id
  need_cmd jq
  need_cmd bastion-bootstrap-token-issue

  parse_args "$@"
  validate_policy

  if [[ "$BOOTSTRAP_ALL" -eq 1 ]]; then
    bootstrap_all_users
  else
    bootstrap_user "$TARGET_USER"
  fi

  log_info "Done."
}

main "$@"
